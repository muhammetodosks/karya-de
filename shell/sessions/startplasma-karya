#!/bin/bash
# Karya DE - Plasma session startup
# Starts KWin (Karya fork) with Karya panel layout

export KDE_SESSION_VERSION=6
export KDE_FULL_SESSION=true
export DESKTOP_SESSION=karya
export XDG_SESSION_DESKTOP=karya
export XDG_CURRENT_DESKTOP=KDE:plasmawayland
export XDG_SESSION_TYPE=wayland

# Load Karya environment
if [ -f /etc/xdg/karya/env.sh ]; then
    source /etc/xdg/karya/env.sh
fi

# Start plasma session
exec /usr/lib/plasma-dbus-run-session-if-needed /usr/bin/startplasma-wayland
