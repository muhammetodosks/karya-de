# Maintainer: Karya DE Team

pkgname=karya-notes
pkgver=1.0.0
pkgrel=1
pkgdesc="Karya DE - Basit ve hizli not defteri"
arch=('x86_64')
url="https://karya-de.org"
license=('GPL2')
depends=('python' 'python-pyqt6')
source=("src/karya-notes.py" "karya-notes.desktop")
sha256sums=('SKIP' 'SKIP')

package() {
    install -Dm755 "$srcdir/karya-notes.py" "$pkgdir/usr/bin/karya-notes"
    install -Dm644 "$srcdir/karya-notes.desktop" "$pkgdir/usr/share/applications/karya-notes.desktop"
}
