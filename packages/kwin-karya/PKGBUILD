# Maintainer: Karya DE Team

pkgname=kwin-karya
pkgver=6.0.0
pkgrel=4
pkgdesc="Karya DE - Fork of KWin with custom tiling, gestures, glassmorphism"
arch=('x86_64')
url="https://github.com/muhammetodosks/kwin"
license=('GPL2')
depends=(
    qt6-base qt6-declarative qt6-wayland
    kconfig kcoreaddons kcrash kdbusaddons kdeclarative
    kglobalaccel kguiaddons ki18n kiconthemes kio
    kitemmodels kitemviews kpackage kservice kwidgetsaddons
    kwindowsystem kxmlgui kwayland
    libepoxy libxcb xcb-util-cursor xcb-util-keysyms
    xcb-util-wm xcb-util-xrm
    libdrm mesa wayland
    systemd-libs
)
optdepends=(
    'elogind: lightweight logind (alternative to systemd-libs)'
)
makedepends=(
    cmake extra-cmake-modules
    wayland-protocols plasma-wayland-protocols
    kauth kidletime ksvg knewstuff krunner knotifications
    kdoctools kirigami libplasma kdecoration
    kglobalacceld kscreenlocker plasma-activities
    libcanberra libxkbcommon xorg-xwayland libx11
    libxcvt libdisplay-info pipewire libevdev
    aurorae breeze vulkan-headers vulkan-icd-loader
    libqaccessibilityclient-qt6
    qt6-shadertools qt6-tools
    libei
)
provides=('kwin')
conflicts=('kwin')
source=("https://github.com/muhammetodosks/kwin/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir"
    cd "$(find . -maxdepth 1 -type d | grep -v '^\.$' | head -1)"
    # Patch all .kcfg files for KF6 6.28+ compatibility
    # kconfig_compiler 6.28+ generates int assignments for Enum types,
    # causing type mismatch errors (e.g. KWin::DecorationPolicy → int)
    find . -name '*.kcfg' -exec sed -i 's|type="Enum"|type="Int"|' {} +
    cmake -B build -S . \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        -DKWIN_BUILD_KCMS=OFF \
        -DKWIN_BUILD_DECORATIONS=ON \
        -DKWIN_BUILD_TABBOX=OFF \
        -DKWIN_BUILD_OVERVIEW=OFF
    cmake --build build --parallel "$(nproc)"
}

package() {
    cd "$srcdir/$(find . -maxdepth 1 -type d | grep -v '^\.$' | head -1)"
    DESTDIR="$pkgdir" cmake --install build
}
